{
  "name": "tps-auto-base-embed",
  "version": "0.1.0",
  "private": true,
  "description": "Render a chosen Base at the bottom of every note without embedding it manually.",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "test": "tsc -p tsconfig.tests.json && node --test .test-dist/tests/settings-model.test.js",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "bases",
    "embed"
  ],
  "author": "Codex",
  "license": "ISC",
  "devDependencies": {
    "@types/node": "^20.11.2",
    "builtin-modules": "3.3.0",
    "esbuild": "^0.19.3",
    "obsidian": "latest",
    "typescript": "^5.3.3"
  }
}
